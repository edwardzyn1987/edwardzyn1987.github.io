---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PoemNav from '../../components/PoemNav.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const poems = await getCollection('poems');
  const sorted = poems.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

  return sorted.map((poem, index) => ({
    params: { slug: poem.id },
    props: {
      poem,
      prevPoem: index < sorted.length - 1
        ? { title: sorted[index + 1].data.title, slug: sorted[index + 1].id }
        : null,
      nextPoem: index > 0
        ? { title: sorted[index - 1].data.title, slug: sorted[index - 1].id }
        : null,
    },
  }));
}

const { poem, prevPoem, nextPoem } = Astro.props;
const { Content } = await render(poem);

const dateStr = poem.data.date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const VIDEO_CDN = 'https://cdn.jsdelivr.net/gh/edwardzyn1987/edwardzyn1987.github.io@main/public/videos';
const videoBase = poem.data.video?.replace(/\.mp4$/, '');
const encodedBase = videoBase ? encodeURIComponent(videoBase) : '';
const videoUrlHls = videoBase
  ? (import.meta.env.PROD ? `${VIDEO_CDN}/${encodedBase}/playlist.m3u8` : `/videos/${encodedBase}/playlist.m3u8`)
  : null;
const videoUrlMp4 = poem.data.video
  ? (import.meta.env.PROD ? `${VIDEO_CDN}/${encodeURIComponent(poem.data.video)}` : `/videos/${encodeURIComponent(poem.data.video)}`)
  : null;
---

<BaseLayout title={poem.data.title}>
  <main class="poem-detail">
    <nav class="breadcrumb">
      <a href="/">首页</a>
      <span class="sep">/</span>
      <a href={`/poems?category=${encodeURIComponent(poem.data.category)}`}>{poem.data.category}</a>
      <span class="sep">/</span>
      <span>{poem.data.title}</span>
    </nav>

    <article class="poem-article">
      <div class="poem-title-row">
        <h1 class="poem-title">{poem.data.title}</h1>
        {poem.data.video && (
          <button class="video-inline-btn" id="video-btn" aria-label="观看朗诵" title="观看朗诵">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none">
              <rect x="2" y="4" width="14" height="14" rx="2" stroke="currentColor" stroke-width="1.8" fill="none"/>
              <path d="M18 8l4-2.5v11L18 14" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" fill="none"/>
            </svg>
            <span class="video-inline-label">观看</span>
          </button>
        )}
      </div>
      <p class="poem-meta">{poem.data.category} · {dateStr}</p>
      <div class="poem-divider"></div>
      <div class="poem-body">
        <Content />
      </div>
      <div class="poem-tags">
        <span class="tag">{poem.data.category}</span>
        {poem.data.tags.map(tag => <span class="tag">{tag}</span>)}
      </div>
      {poem.data.note && (
        <div class="poem-note">
          <h4>创 作 手 记</h4>
          <p>{poem.data.note}</p>
        </div>
      )}
      {poem.data.originalPoem && (
        <div class="poem-original">
          <h4>原 玉</h4>
          <p class="original-title">{poem.data.originalPoem.title}</p>
          <p class="original-author">{poem.data.originalPoem.author}</p>
          <pre class="original-text">{poem.data.originalPoem.text}</pre>
        </div>
      )}
    </article>

    <PoemNav prevPoem={prevPoem} nextPoem={nextPoem} />

    {poem.data.video && (
      <div class="video-modal" id="video-modal">
        <div class="video-modal-backdrop" id="video-modal-backdrop"></div>
        <button class="video-modal-close" id="video-modal-close" aria-label="关闭">✕</button>
        <div class="video-modal-content">
          <video id="video-el" controls preload="none"
                 data-hls={videoUrlHls} data-mp4={videoUrlMp4}></video>
        </div>
      </div>
    )}
  </main>
</BaseLayout>

<style>
  .poem-detail {
    max-width: 700px;
    margin: 0 auto;
  }

  .breadcrumb {
    padding: 14px 0;
    margin: 0 40px;
    font-size: 13px;
    color: var(--color-text-muted);
    border-bottom: 1px solid var(--color-border);
  }

  .breadcrumb a {
    color: var(--color-primary);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    text-decoration: underline;
  }

  .breadcrumb .sep {
    margin: 0 8px;
    color: var(--color-text-muted);
  }

  .poem-article {
    text-align: center;
    padding: 50px 40px 30px;
  }

  .poem-title {
    font-family: var(--font-brush);
    font-size: 36px;
    color: var(--color-text-title);
    letter-spacing: 8px;
    margin-bottom: 10px;
    font-weight: normal;
  }

  .poem-meta {
    font-size: 14px;
    color: var(--color-text-muted);
    letter-spacing: 2px;
  }

  .poem-divider {
    width: 50px;
    height: 1px;
    background: var(--color-primary-light);
    margin: 20px auto 30px;
  }

  .poem-body {
    font-size: 20px;
    color: var(--color-text-body);
    line-height: 2.4;
    letter-spacing: 3px;
  }

  .poem-body :global(p) {
    margin-bottom: 0;
  }

  .poem-tags {
    margin-top: 30px;
    display: flex;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .poem-note {
    margin-top: 36px;
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
    text-align: left;
  }

  .poem-note h4 {
    font-size: 14px;
    color: var(--color-primary);
    letter-spacing: 4px;
    margin-bottom: 10px;
    font-weight: 600;
  }

  .poem-note p {
    font-size: 14px;
    color: var(--color-text-secondary);
    line-height: 1.9;
  }

  .poem-original {
    margin-top: 36px;
    padding: 24px 28px;
    background: rgba(218, 198, 161, 0.15);
    border: 1px solid var(--color-primary-light);
    border-radius: 8px;
    text-align: center;
  }

  .poem-original h4 {
    font-size: 14px;
    color: var(--color-primary);
    letter-spacing: 6px;
    margin-bottom: 16px;
    font-weight: 600;
  }

  .original-title {
    font-family: var(--font-brush);
    font-size: 22px;
    color: var(--color-text-title);
    letter-spacing: 4px;
    margin-bottom: 4px;
    font-weight: 600;
  }

  .original-author {
    font-size: 13px;
    color: var(--color-text-muted);
    letter-spacing: 2px;
    margin-bottom: 18px;
  }

  .original-text {
    font-family: var(--font-serif);
    font-size: 16px;
    color: var(--color-text-body);
    line-height: 2.0;
    letter-spacing: 2px;
    white-space: pre-line;
    margin: 0;
    background: transparent;
    padding: 0;
    border: none;
    text-align: center;
  }

  @media (max-width: 768px) {
    .poem-article { padding: 30px 20px 20px; }
    .breadcrumb { margin: 0 20px; }
    .poem-title { font-size: 28px; letter-spacing: 4px; }
    .poem-body { font-size: 18px; }
  }

  .poem-title-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
  }

  .video-inline-btn {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: rgba(139, 115, 85, 0.1);
    border: 1px solid var(--color-primary-light);
    border-radius: 20px;
    padding: 6px 14px;
    cursor: pointer;
    color: var(--color-primary);
    font-family: var(--font-serif);
    font-size: 12px;
    transition: all 0.2s;
    white-space: nowrap;
  }

  .video-inline-btn:hover {
    background: rgba(139, 115, 85, 0.2);
    transform: scale(1.05);
  }

  .video-inline-label {
    letter-spacing: 1px;
  }

  .video-modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 1000;
    align-items: center;
    justify-content: center;
  }

  .video-modal.open {
    display: flex;
  }

  .video-modal-backdrop {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.7);
  }

  .video-modal-content {
    position: relative;
    max-width: 800px;
    width: 90%;
    max-height: 90vh;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    background: #000;
  }

  .video-modal-content video {
    display: block;
    width: 100%;
    max-height: 90vh;
    height: auto;
    background: #000;
    object-fit: contain;
  }

  .video-modal-close {
    position: absolute;
    top: 20px;
    right: 20px;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.7);
    color: #fff;
    border: 2px solid rgba(255, 255, 255, 0.5);
    font-size: 20px;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 220;
    transition: background 0.2s, transform 0.2s;
  }

  .video-modal-close:hover {
    background: rgba(0, 0, 0, 0.95);
    transform: scale(1.1);
  }
</style>

<script>
  const btn = document.getElementById('video-btn');
  const modal = document.getElementById('video-modal');
  const backdrop = document.getElementById('video-modal-backdrop');
  const closeBtn = document.getElementById('video-modal-close');
  const video = document.getElementById('video-el') as HTMLVideoElement & { _hls?: any };

  // Move modal to body to escape parent stacking contexts (e.g. main z-index:1)
  if (modal && modal.parentElement !== document.body) {
    document.body.appendChild(modal);
  }

  let attached = false;

  async function attachVideo() {
    if (attached || !video) return;
    attached = true;
    const hlsUrl = video.dataset.hls;
    const mp4Url = video.dataset.mp4;

    if (!hlsUrl) {
      if (mp4Url) video.src = mp4Url;
      return;
    }

    // Safari / iOS: native HLS only (Chromium also returns truthy for canPlayType
    // but cannot actually decode HLS playlists, so we must check UA).
    const ua = navigator.userAgent;
    const isSafari = /^((?!chrome|android|edg|firefox).)*safari/i.test(ua);
    if (isSafari && video.canPlayType('application/vnd.apple.mpegurl')) {
      video.src = hlsUrl;
      return;
    }

    try {
      const { default: Hls } = await import('hls.js');
      if (Hls.isSupported()) {
        const hls = new Hls({
          // Aggressive buffering for short poetry videos (~60-90s).
          // Goal: download whole video upfront after a few segments,
          // so playback never stalls even if jsDelivr CDN has cache misses.
          maxBufferLength: 60,           // target forward buffer (default 30)
          maxMaxBufferLength: 600,       // hard cap (default 600) — allow whole-video buffering
          maxBufferSize: 60 * 1000 * 1000, // 60MB cap (default 60MB)
          backBufferLength: 30,          // keep 30s behind playhead (default 90, less is fine for short clips)
          highBufferWatchdogPeriod: 1,   // check stall every 1s (default 2)
          nudgeMaxRetry: 10,             // try harder to recover from stalls (default 3)
          startFragPrefetch: true,       // prefetch first segment ASAP
        });
        hls.loadSource(hlsUrl);
        hls.attachMedia(video);
        hls.on(Hls.Events.ERROR, (_event, data) => {
          if (data.fatal && mp4Url) {
            hls.destroy();
            video._hls = undefined;
            video.src = mp4Url;
          }
        });
        video._hls = hls;
        return;
      }
    } catch (_) {
      /* hls.js failed to load — fall back to MP4 */
    }
    if (mp4Url) video.src = mp4Url;
  }

  async function openModal() {
    modal?.classList.add('open');
    await attachVideo();
    video?.play().catch(() => { /* autoplay may be blocked; user can press play */ });
  }

  function closeModal() {
    video?.pause();
    modal?.classList.remove('open');
  }

  btn?.addEventListener('click', openModal);
  backdrop?.addEventListener('click', closeModal);
  closeBtn?.addEventListener('click', closeModal);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal?.classList.contains('open')) {
      closeModal();
    }
  });
</script>
